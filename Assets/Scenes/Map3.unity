      side: 1
      hasOtherCharacter: 0
    - characterName: "\u0E1E\u0E48\u0E2D"
      text: "\u0E21\u0E31\u0E19\u0E2D\u0E31\u0E15\u0E23\u0E32\u0E22\u0E40\u0E01\u0E34\u0E19\u0E44\u0E1B"
      characterSprite: {fileID: 6561009586784664154, guid: ae9e1b371c7a44f409cf719b516e9595, type: 3}
      side: 1
      hasOtherCharacter: 0
    - characterName: "\u0E08\u0E2D\u0E23\u0E4C\u0E19"
      text: "\u0E1E\u0E48\u0E2D \u0E1C\u0E21\u0E42\u0E15\u0E41\u0E25\u0E49\u0E27\u0E19\u0E30"
      characterSprite: {fileID: 6863246505373101655, guid: fc0aa55337e619043a1b0f2bf177bf29, type: 3}
      side: 0
      hasOtherCharacter: 1
    - characterName: "\u0E08\u0E2D\u0E23\u0E4C\u0E19"
      text: "\u0E21\u0E31\u0E19\u0E16\u0E36\u0E07\u0E40\u0E27\u0E25\u0E32\u0E17\u0E35\u0E48\u0E1C\u0E21\u0E15\u0E49\u0E2D\u0E07\u0E2D\u0E2D\u0E01\u0E44\u0E1B\u0E43\u0E0A\u0E49\u0E0A\u0E35\u0E27\u0E34\u0E15\u0E41\u0E25\u0E49\u0E27"
      characterSprite: {fileID: 6863246505373101655, guid: fc0aa55337e619043a1b0f2bf177bf29, type: 3}
      side: 0
      hasOtherCharacter: 1
    - characterName: "\u0E1E\u0E48\u0E2D"
      text: "\u0E16\u0E49\u0E32\u0E07\u0E31\u0E49\u0E19\u0E01\u0E48\u0E2D\u0E19\u0E41\u0E01\u0E08\u0E30\u0E44\u0E1B...."
      characterSprite: {fileID: 6561009586784664154, guid: ae9e1b371c7a44f409cf719b516e9595, type: 3}
      side: 1
      hasOtherCharacter: 1
    - characterName: "\u0E1E\u0E48\u0E2D"
      text: "\u0E41\u0E01\u0E15\u0E49\u0E2D\u0E07\u0E2A\u0E39\u0E49\u0E01\u0E31\u0E1A\u0E1E\u0E48\u0E2D\u0E01\u0E48\u0E2D\u0E19"
      characterSprite: {fileID: 6561009586784664154, guid: ae9e1b371c7a44f409cf719b516e9595, type: 3}
      side: 1
      hasOtherCharacter: 1
    - characterName: "\u0E1E\u0E48\u0E2D"
      text: "\u0E40\u0E1E\u0E37\u0E48\u0E2D\u0E1E\u0E34\u0E2A\u0E39\u0E08\u0E19\u0E4C\u0E27\u0E48\u0E32\u0E41\u0E01\u0E40\u0E2D\u0E32\u0E15\u0E31\u0E27\u0E23\u0E2D\u0E14\u0E43\u0E19\u0E42\u0E25\u0E01\u0E17\u0E35\u0E48\u0E42\u0E2B\u0E14\u0E23\u0E49\u0E32\u0E22\u0E19\u0E35\u0E49\u0E44\u0E14\u0E49"
