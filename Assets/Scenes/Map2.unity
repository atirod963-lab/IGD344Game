--- !u!114 &1648636618
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1648636615}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: aa19f61b12025fd4eb22a3a842f386e1, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  dialogueManager: {fileID: 1648636617}
  timeline: {fileID: 1173291382}
  dialogueSets:
  - setName: 
    lines:
    - characterName: "\u0E08\u0E2D\u0E23\u0E4C\u0E19"
      text: "\u0E2B\u0E27\u0E31\u0E07\u0E27\u0E48\u0E32\u0E08\u0E30\u0E2B\u0E19\u0E35\u0E1E\u0E49\u0E19\u0E41\u0E25\u0E49\u0E27\u0E19\u0E30"
  - setName: 
    lines:
    - characterName: "\u0E08\u0E2D\u0E23\u0E4C\u0E19"
      text: "\u0E2E\u0E31\u0E48\u0E19\u0E41\u0E19\u0E48! \u0E08\u0E30\u0E23\u0E35\u0E1A\u0E44\u0E1B\u0E44\u0E2B\u0E19\u0E08\u0E4A\u0E30\u0E44\u0E2D\u0E2B\u0E19\u0E39"
    - characterName: "\u0E42\u0E08\u0E23"
      text: "\u0E40\u0E25\u0E34\u0E01\u0E27\u0E34\u0E48\u0E07\u0E2B\u0E19\u0E35\u0E41\u0E25\u0E30\u0E2A\u0E48\u0E07\u0E02\u0E2D\u0E07\u0E21\u0E35\u0E04\u0E48\u0E32\u0E21\u0E32\u0E43\u0E2B\u0E49\u0E2B\u0E21\u0E14\u0E2A\u0E30"
    - characterName: "\u0E08\u0E2D\u0E23\u0E4C\u0E19"
      text: "(\u0E44\u0E21\u0E48\u0E21\u0E35\u0E17\u0E32\u0E07\u0E23\u0E2D\u0E14\u0E41\u0E25\u0E49\u0E27\u0E2A\u0E34
        \u0E04\u0E07\u0E21\u0E35\u0E41\u0E15\u0E48\u0E15\u0E49\u0E2D\u0E07\u0E2A\u0E39\u0E49\u0E40\u0E17\u0E48\u0E32\u0E19\u0E31\u0E49\u0E19\u0E41\u0E2B\u0E25\u0E30)"
    - characterName: "\u0E08\u0E2D\u0E23\u0E4C\u0E19"
      text: "*\u0E15\u0E31\u0E49\u0E07\u0E17\u0E48\u0E32\u0E15\u0E48\u0E2D\u0E2A\u0E39\u0E49*"
    - characterName: "\u0E42\u0E08\u0E23"
      text: "\u0E44\u0E2D\u0E40\u0E27\u0E23\u0E19\u0E35\u0E48\u0E21\u0E31\u0E19\u0E2A\u0E39\u0E49\u0E27\u0E48\u0E30"
